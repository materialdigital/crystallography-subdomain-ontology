############################
#   Named Individuals
############################

# Individual: <http://qudt.org/vocab/unit/ANGSTROM3> (Cubic Angstrom)

AnnotationAssertion(<http://purl.org/dc/terms/description> <http://qudt.org/vocab/unit/ANGSTROM3> "A unit that is a non-SI unit, specifically a CGS unit,  of polarizability known informally as
    polarizability volume.  The SI defined units for polarizability are C*m^2/V and can be converted to $Angstr\\ddot{o}m$^3 by
    multiplying the SI value by 4 times pi times the vacuum permittivity and then converting the resulting m^3 to
    $Angstr\\ddot{o}m$^3 through the SI base 10 conversion (multiplying by 10^-30).
  "^^<http://qudt.org/schema/qudt/LatexString>)
AnnotationAssertion(<http://qudt.org/schema/qudt/symbol> <http://qudt.org/vocab/unit/ANGSTROM3> "Å³")
AnnotationAssertion(rdfs:isDefinedBy <http://qudt.org/vocab/unit/ANGSTROM3> <http://qudt.org/vocab/unit>)
AnnotationAssertion(rdfs:label <http://qudt.org/vocab/unit/ANGSTROM3> "Cubic Angstrom")
AnnotationAssertion(rdfs:label <http://qudt.org/vocab/unit/ANGSTROM3> "Cubic Angstrom"@en)
AnnotationAssertion(rdfs:label <http://qudt.org/vocab/unit/ANGSTROM3> "Cubic Angstrom"@en-us)


)