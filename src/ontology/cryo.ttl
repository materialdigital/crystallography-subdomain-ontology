###  https://w3id.org/pmd/cryo/CRYO_0000043
cryo:CRYO_0000043 rdf:type owl:NamedIndividual ;
                  rdfs:label "primitive"@en ;
                  skos:altLabel "P" ;
                  skos:definition "Primitive centering type is a centering type, where lattice points are located only on the corners of a unit cell, i.e., at coordinates (0,0,0)."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000044
cryo:CRYO_0000044 rdf:type owl:NamedIndividual ;
                  rdfs:label "body centered"@en ;
                  skos:altLabel "I" ;
                  skos:definition "Body centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of a unit cell, i.e., at coordinates (1/2,1/2,1/2)."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000045
cryo:CRYO_0000045 rdf:type owl:NamedIndividual ;
                  rdfs:label "face centered"@en ;
                  skos:altLabel "F" ;
                  skos:definition "Face centered centering type is a centering type, where lattice points are located  on the corners of a unit cell, i.e., at coordinates (0,0,0), and at the center of each faces of a unit cell, i.e., at coordinates (1/2,1/2,0), (1/2,0,1/2), and (0,1/2,1/2)."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000046
cryo:CRYO_0000046 rdf:type owl:NamedIndividual ;
                  rdfs:comment "Add symbol annotation property" ;
                  rdfs:label "base centered"@en ;
                  skos:altLabel "C" ;
                  skos:definition "Base centered centering type is a centering type, where lattice points are located on the corners of a unit cell, i.e., at coordinates (0,0,0), and one additional lattice point is located at the center of a base of the cell, i.e., at coordinates (1/2,1/2,0)."@en .


