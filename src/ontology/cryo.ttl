#################################################################
#    Annotations
#################################################################

obo:UO_0000076 obo:IAO_0000115 "A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution." ;
               oboInOwl:hasExactSynonym "(x)" ,
                                        "chi" ;
               rdfs:label "mole fraction" .

[ rdf:type owl:Axiom ;
   owl:annotatedSource obo:UO_0000076 ;
   owl:annotatedProperty obo:IAO_0000115 ;
   owl:annotatedTarget "A concentration unit which denotes the number of moles of solute as a proportion of the total number of moles in a solution." ;
   oboInOwl:hasDbXref "Wikipedia:Wikipedia"
 ] .


cryo:CRYO_0000152 rdfs:label "P 2yb space group" ,
                             "has Miller indices family"@en ;
                  owl:deprecated "true"^^xsd:boolean .


cryo:CRYO_0000157 rdfs:label "C -2yc space group" ,
                             "Miller indices family of"@en ;
                  owl:deprecated "true"^^xsd:boolean .


cryo:CRYO_0000158 rdfs:label "-P 2y space group" ,
                             "under symmetry"@en ;
                  owl:deprecated "true"^^xsd:boolean .


cryo:CRYO_0000162 rdfs:label "-P 2ybc space group" ,
                             "has Miller indices family under cubic symmetry"@en ;
                  owl:deprecated "true"^^xsd:boolean .


cryo:CRYO_0000164 rdfs:label "P 2 2 space group" ,
                             "denoted by family"@en .


cryo:CRYO_0000168 rdfs:comment "'denoted by' o 'member of' o 'has Miller indices family under cubic symmetry'" ,
                               "'denoted by' o 'under  symmetry' o 'is cubic' o  inverse ('under  symmetry') o 'has member' o 'member of'" ,
                               "'denoted by' o 'under cubic symmetry' o 'member of' o 'under cubic symmetry'" ;
                  rdfs:label "C 2c 2 space group" ,
                             "denoted by family under cubic symmetry"@en .


cryo:CRYO_0000170 rdfs:label "F 2 2 space group" ,
                             "is cubic"@en .


