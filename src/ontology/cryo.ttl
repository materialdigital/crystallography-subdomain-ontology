###  https://w3id.org/pmd/co/PMD_0020217
co:PMD_0020217 rdf:type owl:NamedIndividual ;
               rdfs:label "short range order"@en ;
               skos:definition "periodic arrangement of structural features up to a few entities"@en .


###  https://w3id.org/pmd/co/PMD_0020218
co:PMD_0020218 rdf:type owl:NamedIndividual ;
               rdfs:label "medium range order"@en ;
               skos:definition "periodic arrangement of structural features of many entities"@en .


###  https://w3id.org/pmd/co/PMD_0020219
co:PMD_0020219 rdf:type owl:NamedIndividual ;
               rdfs:label "long range order"@en ;
               skos:definition "periodic arrangement of structural features of virtually all entities"@en .


###  https://w3id.org/pmd/co/PMD_0020242
co:PMD_0020242 rdf:type owl:NamedIndividual ;
               rdfs:label "no range order"@en ;
               skos:definition "no periodic arrangement of structural features of entites"@en .


###  https://w3id.org/pmd/cryo/CRYO_0000029
cryo:CRYO_0000029 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000030 ,
                                    cryo:CRYO_0000031 ,
                                    cryo:CRYO_0000032 ,
                                    cryo:CRYO_0000033 ,
                                    cryo:CRYO_0000034 ,
                                    cryo:CRYO_0000035 ;
                  rdfs:label "triclinic"@en ;
                  skos:definition "Triclinic crystal system is a crystal system with only translational symmetry."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000030
cryo:CRYO_0000030 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000031 ,
                                    cryo:CRYO_0000032 ,
                                    cryo:CRYO_0000033 ,
                                    cryo:CRYO_0000034 ,
                                    cryo:CRYO_0000035 ;
                  rdfs:label "monoclinic"@en ;
                  skos:definition "Monoclinic crystal system is a crystal system with one twofold rotation axis or one mirror plane."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000031
cryo:CRYO_0000031 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000032 ,
                                    cryo:CRYO_0000033 ,
                                    cryo:CRYO_0000034 ,
                                    cryo:CRYO_0000035 ;
                  rdfs:label "orthorhombic"@en ;
                  skos:definition "Orthorhombic crystal system is a crystal system with three twofold rotation axes or one twofold rotation axis and two mirror planes"@en .


###  https://w3id.org/pmd/cryo/CRYO_0000032
cryo:CRYO_0000032 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000033 ,
                                    cryo:CRYO_0000034 ,
                                    cryo:CRYO_0000035 ;
                  rdfs:label "tetragonal"@en ;
                  skos:definition "Tetragonal crystal system is a crystal system with one fourfold rotation axis."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000033
cryo:CRYO_0000033 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000034 ,
                                    cryo:CRYO_0000035 ;
                  rdfs:label "rhombohedral"@en ;
                  skos:altLabel "trigonal"@en ;
                  skos:definition "Rhombohedral ( trigonal) crystal system is a crystal system with one threefold rotation axis."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000034
cryo:CRYO_0000034 rdf:type owl:NamedIndividual ;
                  owl:differentFrom cryo:CRYO_0000035 ;
                  rdfs:label "hexagonal"@en ;
                  skos:definition "Hexagonal crystal system is a crystal system with one sixfold rotation axis."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000035
cryo:CRYO_0000035 rdf:type owl:NamedIndividual ;
                  rdfs:label "cubic"@en ;
                  skos:definition "Cubic crystal system is a crystal system with fourfold rotation axes."@en .


