# Class: <https://w3id.org/pmd/cryo/CRYO_0000143> (cubic equivalency assertion)

AnnotationAssertion(rdfs:comment <https://w3id.org/pmd/cryo/CRYO_0000143> "((('has member' value CRYO_0000089) or ('has member' value CRYO_0000095) or ('has member' value CRYO_0000096) or ('has member' value CRYO_0000097) or ('has member' value CRYO_0000098) or ('has member' value CRYO_0000099))
 and ('has Miller indices family' value CRYO_0000039)) or ((('has member' value CRYO_0000101) or ('has member' value CRYO_0000102) or ('has member' value CRYO_0000103) or ('has member' value CRYO_0000104) or ('has member' value CRYO_0000105) or ('has member' value CRYO_0000106) or ('has member' value CRYO_0000107) or ('has member' value CRYO_0000108) or ('has member' value CRYO_0000109) or ('has member' value CRYO_0000110) or ('has member' value CRYO_0000111) or ('has member' value CRYO_0000112))
 and ('has Miller indices family' value CRYO_0000038)) or ((('has member' value CRYO_0000114) or ('has member' value CRYO_0000115) or ('has member' value CRYO_0000116) or ('has member' value CRYO_0000117) or ('has member' value CRYO_0000118) or ('has member' value CRYO_0000119) or ('has member' value CRYO_0000120) or ('has member' value CRYO_0000121))
 and ('has Miller indices family' value CRYO_0000037))")
AnnotationAssertion(rdfs:label <https://w3id.org/pmd/cryo/CRYO_0000143> "cubic equivalency assertion"@en)
AnnotationAssertion(owl:deprecated <https://w3id.org/pmd/cryo/CRYO_0000143> "true"^^xsd:boolean)
AnnotationAssertion(<http://www.w3.org/2004/02/skos/core#definition> <https://w3id.org/pmd/cryo/CRYO_0000143> "cubic equivalency assertion is a symmetry equivalency assertion which is used to infer crystallographic equivalence between single crystallographic direction /plane and family of directions/planes under the cubic crystal symmetry.
In particular, it considers <100>, <110>, and <111> families of crystallographic directions, as well as {100}, {110}, {111} families of crystallographic planes"@en)
EquivalentClasses(<https://w3id.org/pmd/cryo/CRYO_0000143> ObjectIntersectionOf(<https://w3id.org/pmd/cryo/CRYO_0000124> ObjectHasValue(<https://w3id.org/pmd/cryo/CRYO_0000158> <https://w3id.org/pmd/cryo/CRYO_0000035>)))
SubClassOf(<https://w3id.org/pmd/cryo/CRYO_0000143> <https://w3id.org/pmd/cryo/CRYO_0000124>)
SubClassOf(<https://w3id.org/pmd/cryo/CRYO_0000143> ObjectHasSelf(<https://w3id.org/pmd/cryo/CRYO_0000170>))


