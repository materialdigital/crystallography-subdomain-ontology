               skos:definition "data property that relates an information content entity to a literal"@en .


###  https://w3id.org/pmd/cryo/CRYO_0000016
cryo:CRYO_0000016 rdf:type owl:DatatypeProperty ;
                  rdfs:range xsd:integer ;
                  rdfs:label "has Miller index"@en ;
                  skos:definition "has Miller index is a top-level annotation property to specify Miller indices of crystallographic plane, direction, or lattice point."@en .


###  https://w3id.org/pmd/cryo/CRYO_0000017
cryo:CRYO_0000017 rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf cryo:CRYO_0000016 ;
                  rdfs:label "has h"@en ;
                  skos:definition "has h specifies an integer of a h Miller index in a hkl set"@en .


###  https://w3id.org/pmd/cryo/CRYO_0000018
cryo:CRYO_0000018 rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf cryo:CRYO_0000016 ;
                  rdfs:label "has k"@en ;
                  skos:definition "has k specifies an integer of a k Miller index in a hkl set"@en .


###  https://w3id.org/pmd/cryo/CRYO_0000019
cryo:CRYO_0000019 rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf cryo:CRYO_0000016 ;
                  rdfs:label "has l"@en ;
                  skos:definition "has l specifies an integer of a l Miller index in a hkl set"@en .


