    <!-- https://w3id.org/pmd/cryo/CRYO_0000001 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000001"/>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000002 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000002">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0040001"/>
        <rdfs:label xml:lang="en">lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">Lattice parameter is a quality of a unit cell which describes the length of (three) dimensions along of the unit cell&apos;s x-, y-, and z-directions.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000003 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000003">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000002"/>
        <rdfs:label xml:lang="en">a lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">A length of a unit cell along its x-axis</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000004 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000004">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000002"/>
        <rdfs:label xml:lang="en">b lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">A length of a unit cell along its y-axis</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000005 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000005">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000002"/>
        <rdfs:label xml:lang="en">c lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">A length of a unit cell along its z-axis</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000006 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000006">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:comment>TODO check the naming conventions</rdfs:comment>
        <rdfs:label xml:lang="en">angular lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">Angular lattice parameter is a relational quality between two axes in a unit cell</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000007 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000007">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000006"/>
        <rdfs:label xml:lang="en">α lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">α lattice parameter is an anlge between y- and z-directions in a unit cell</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000008 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000008">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000006"/>
        <rdfs:label xml:lang="en">β lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">β lattice parameter is an anlge between x- and z-directions in a unit cell</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000009 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000009">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000006"/>
        <rdfs:label xml:lang="en">γ lattice parameter</rdfs:label>
        <skos:definition xml:lang="en">γ lattice parameter is an anlge between x- and z-directions in a unit cell</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000013 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000013">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000145"/>
        <rdfs:comment>TODO add symbol annotation property</rdfs:comment>
        <rdfs:label xml:lang="en">interplanar spacing</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000015 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">lattice angle</rdfs:label>
        <skos:definition xml:lang="en">Lattice angle is a quality of a unit cell which describes the angle between three axes in a unit cell.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000026 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/co/PMD_0020003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000028"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">crystal system</rdfs:label>
        <skos:definition xml:lang="en">Crystal system is a quality of a (real) crystal which defines its symmetry based on the rotational and mirror symmetries of the actual atomic arrangements.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000027 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000027">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000001"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000036"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">lattice centering</rdfs:label>
        <skos:definition xml:lang="en">Lattice centering is an intensive quality ofa crystal lattice which the geometric arrangement of lattice points in a unit cell. It is specified by one of the 4 lattice centering value.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000028 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000028"/>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000036 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000036"/>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000037 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000037">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000015"/>
        <rdfs:label xml:lang="en">alpha angle</rdfs:label>
        <skos:altLabel xml:lang="en">α anlge</skos:altLabel>
        <skos:definition xml:lang="en">α anlge is an angle in a unit cell between y- and z-axes.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000038 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000038">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000015"/>
        <rdfs:label xml:lang="en">beta angle</rdfs:label>
        <skos:altLabel xml:lang="en">β anlge</skos:altLabel>
        <skos:definition xml:lang="en">β anlge is an angle in a unit cell between x- and z-axes.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000039 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000039">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000015"/>
        <rdfs:label xml:lang="en">gamma angle</rdfs:label>
        <skos:altLabel xml:lang="en">γ angle</skos:altLabel>
        <skos:definition>γ anlge is an angle in a unit cell between x- and y-axes.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000141 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">space group</rdfs:label>
        <skos:definition xml:lang="en">space group is a quality of some crystal  that defines the symmetry combining all point group symmetries with all lattice translation symmetries</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000142 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000142">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">space group type</rdfs:label>
        <skos:definition xml:lang="en">Space group type is a categorical value specification of a space group. It includes all the 230 3D space groups.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000386 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000386">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">unit cell volume</rdfs:label>
        <skos:definition xml:lang="en">The volume of a unit cell is the 3D space occupied by the repeating structural unit in a crystal lattice.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000387 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000387">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="en">point group</rdfs:label>
        <rdfs:seeAlso>https://www.math.ru.nl/~souvi/papers/zkrist09.pdf</rdfs:seeAlso>
        <skos:definition xml:lang="en">point group is a quality of a crystal that defines its symmetry consisting strictly of rotations, reflections, and inversions around a fixed center</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000390 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000390">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">Considers just the lattice points, no atoms</rdfs:comment>
        <rdfs:label xml:lang="en">lattice system</rdfs:label>
        <skos:altLabel xml:lang="en">lattice type</skos:altLabel>
        <skos:definition xml:lang="en">lattice system is a quality of crystal lattice that defines its symmetry based on the 7 categories originating from its point group symmetries of their empty translational frameworks</skos:definition>
    </owl:Class>
</rdf:RDF>



