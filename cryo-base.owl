        <rdfs:label xml:lang="en">point group</rdfs:label>
        <rdfs:seeAlso>https://www.math.ru.nl/~souvi/papers/zkrist09.pdf</rdfs:seeAlso>
        <skos:definition xml:lang="en">point group is a quality of a crystal that defines its symmetry consisting strictly of rotations, reflections, and inversions around a fixed center</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/pmd/cryo/CRYO_0000390 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000390">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0000080"/>
