    <!-- https://w3id.org/pmd/cryo/CRYO_0000392 -->

    <owl:Class rdf:about="https://w3id.org/pmd/cryo/CRYO_0000392">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000029"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000030"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000031"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000032"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000033"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000034"/>
                    <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000035"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0001930"/>
        <rdfs:label xml:lang="en">lattice system value</rdfs:label>
        <skos:definition xml:lang="en">lattice system value is a categorical value specification which describes the grouping of
lattice system based on the point group symmetries of their empty translational frameworks. The specific values are triclinic, monoclinic, orthorhombic, tetragonal, rhombohedral, hexagonal, and cubic.</skos:definition>
    </owl:Class>
    


