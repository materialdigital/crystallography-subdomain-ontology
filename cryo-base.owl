    <!-- https://w3id.org/pmd/cryo/CRYO_0000062 -->

    <owl:ObjectProperty rdf:about="https://w3id.org/pmd/cryo/CRYO_0000062">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000164"/>
