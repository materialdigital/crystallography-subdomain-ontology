        <rdfs:label xml:lang="en">proportion</rdfs:label>
        <skos:altLabel xml:lang="en">concentration</skos:altLabel>
        <skos:altLabel xml:lang="en">fraction</skos:altLabel>
        <skos:definition xml:lang="en">A proportion is a relational quality between two entities (the whole and the part) which quantifies the relation between the whole and its part.</skos:definition>
