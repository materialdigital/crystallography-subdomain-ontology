            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>(((&apos;has member&apos; value CRYO_0000089) or (&apos;has member&apos; value CRYO_0000095) or (&apos;has member&apos; value CRYO_0000096) or (&apos;has member&apos; value CRYO_0000097) or (&apos;has member&apos; value CRYO_0000098) or (&apos;has member&apos; value CRYO_0000099))
 and (&apos;has Miller indices family&apos; value CRYO_0000039)) or (((&apos;has member&apos; value CRYO_0000101) or (&apos;has member&apos; value CRYO_0000102) or (&apos;has member&apos; value CRYO_0000103) or (&apos;has member&apos; value CRYO_0000104) or (&apos;has member&apos; value CRYO_0000105) or (&apos;has member&apos; value CRYO_0000106) or (&apos;has member&apos; value CRYO_0000107) or (&apos;has member&apos; value CRYO_0000108) or (&apos;has member&apos; value CRYO_0000109) or (&apos;has member&apos; value CRYO_0000110) or (&apos;has member&apos; value CRYO_0000111) or (&apos;has member&apos; value CRYO_0000112))
 and (&apos;has Miller indices family&apos; value CRYO_0000038)) or (((&apos;has member&apos; value CRYO_0000114) or (&apos;has member&apos; value CRYO_0000115) or (&apos;has member&apos; value CRYO_0000116) or (&apos;has member&apos; value CRYO_0000117) or (&apos;has member&apos; value CRYO_0000118) or (&apos;has member&apos; value CRYO_0000119) or (&apos;has member&apos; value CRYO_0000120) or (&apos;has member&apos; value CRYO_0000121))
 and (&apos;has Miller indices family&apos; value CRYO_0000037))</rdfs:comment>
        <rdfs:label xml:lang="en">cubic equivalency assertion</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:definition xml:lang="en">cubic equivalency assertion is a symmetry equivalency assertion which is used to infer crystallographic equivalence between single crystallographic direction /plane and family of directions/planes under the cubic crystal symmetry.
In particular, it considers &lt;100&gt;, &lt;110&gt;, and &lt;111&gt; families of crystallographic directions, as well as {100}, {110}, {111} families of crystallographic planes</skos:definition>
    </owl:Class>
    


