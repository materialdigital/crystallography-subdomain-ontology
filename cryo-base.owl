                                            <rdf:Description rdf:about="https://w3id.org/pmd/cryo/CRYO_0000390"/>
                                            <owl:Restriction>
                                                <owl:onProperty rdf:resource="https://w3id.org/pmd/co/PMD_0000077"/>
                                                <owl:hasValue rdf:resource="https://w3id.org/pmd/cryo/CRYO_0000035"/>
