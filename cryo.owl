                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_28685"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/pmd/co/PMD_0020140"/>
        <rdfs:comment xml:lang="en">A Portion Of Matter that consists of only molybdenum atoms.</rdfs:comment>
